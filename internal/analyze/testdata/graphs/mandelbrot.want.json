{
  "order": [
    "centerRe",
    "centerIm",
    "zoom",
    "maxIter",
    "render",
    "depth",
    "intro"
  ],
  "helpers": [
    "escape",
    "shade",
    "pixelBytes"
  ],
  "producer": {
