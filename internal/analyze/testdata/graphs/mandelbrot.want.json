      "params": [
        {
          "name": "cx",
          "type": "float64",
          "kind": "wired"
        },
        {
          "name": "cy",
          "type": "float64",
          "kind": "wired"
        },
        {
          "name": "mag",
          "type": "float64",
          "kind": "wired"
        },
        {
          "name": "limit",
          "type": "int",
          "kind": "wired"
        }
      ],
      "results": [
        {
          "name": "picture",
          "type": "Image"
        }
