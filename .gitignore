# Generated registry — codegen writes via `go build -overlay`, never to the source tree.
# This entry is belt-and-suspenders in case a debug build emits it locally.
notebook_gen.go

# Build output
/notebook
/cmd/notebook/notebook
/driver
*.exe

# Persisted head state (a few floats per notebook). `notebook run` writes
# notebook-head.json next to the source; it is per-user state, never committed.
*.head.json
notebook-head.json

# Go
*.test
*.out
/dist/

# Landing-page build output — regenerate with site/build.sh
site/demos/
site/docs/
# Discovery files generated by site/docgen (from the page list)
site/robots.txt
site/sitemap.xml
site/llms.txt
# The component demo's runtime assets — copied in by site/build.sh (the wasm is
# content-addressed, so its name drifts; index.html + app.js are hand-written and
# committed, these three are generated output).
site/component/notebook.wasm
site/component/wasm_exec.js
site/component/notebook.js
